<script src="http://ajax.googleapis.com/ajax/libs/jquery/1.9.1/jquery.min.js"></script> 


<!-- books.hbs -->
<h1>Books</h1>
{{!-- Create a table --}}
<table id= "book-table">

    {{!-- Header section --}}
    <thead>

        {{!-- For just the first row, we print each key of the row object as a header cell so we
        know what each column means when the page renders --}}
        <tr>
            {{#each data.[0]}}
            <th>
                {{@key}}
            </th>
            {{/each}}
            <th>delete</th>
        </tr>
    </thead>

    {{!-- Body section --}}
    <tbody>

        {{!-- For each row, print the book_id, title, isbn, publication_date in order --}}
        {{#each data}}
        <tr data-value="{{this.book_id}}">
            <td>{{this.book_id}}</td>
            <td>{{this.title}}</td>
            <td>{{this.isbn}}</td>
            <td>{{this.publication_date}}</td>
            <td><button onClick="deleteBook({{this.book_id}})">Delete</button></td>
        </tr>
        {{/each}}
    </tbody>
</table>
<script src="./js/delete_book.js"></script>


{{!-- Form to add a book to the table  --}}
<h2>Add a new book</h2>
<p>To add a new book, please enter the following information below:</p>
<form id="add-book-form-ajax">
    <label for="input-title">Title: </label>
    <input type="text" name="input-title" id="input-title">
    
    <label for="input-isbn">ISBN: </label>
    <input type="text" name="input-isbn" id="input-isbn">

    <label for="input-publication_date">Publication Date: </label>
    <input type="date" name="input-publication_date" id="input-publication_date">

    <input type="submit">

</form>

{{!-- Embed our javascript to handle the DOM manipulation and AJAX request --}}
<script src="./js/add_book.js"></script>


{{!-- Update a book form using a dropdown for titles --}}

<h2>Update a Book</h2>
<p>To update a book's isbn or publication date, select desired title from the dropdown</p>
<form id="update-book-form-ajax">

    <label for="update-title">Title: </label>
    <select name="Title" id = "update-title">
        <option value="test">Select a Book</option>
        {{#each data}}
        <option value="{{this.book_id}}">{{this.title}}</option>
        {{/each}}
    </select>

    <label for="update-isbn">ISBN: </label>
    <input type="text" id="update-isbn" name="update-isbn" placeholder="Enter new ISBN">

    <label for="update-publication_date">Publication Date: </label>
    <input type="date" id="update-publication_date" name="update-publication_date">

    <input type="submit" value="Update Book">

</form>

<script src="./js/update_book.js"></script>